#!/usr/bin/env python3
import concurrent.futures
import json
import os
import random
import re
import shlex
import subprocess
import sys
import threading
import time
from datetime import datetime, timezone
from pathlib import Path

TPUS_DIR = Path.home() / '.config' / 'tpus'
TPUS_CONFIG = TPUS_DIR / 'config.json'
TPUS_STATE_JSON = TPUS_DIR / 'state.json'
TPUS_STATE_TSV = TPUS_DIR / 'state'
STARTUP_SCRIPT = 'curl -fsSL https://stuff.ecntu.com/init.sh | bash'
READY_STATES = {'READY', 'RUNNING', 'ACTIVE', 'HEALTHY'}
MISSING_STATES = {'PREEMPTED', 'TERMINATED', 'STOPPED', 'UNKNOWN', 'MISSING'}
FULL_PROBE_TTL_SECONDS = 3600

# ── colour ────────────────────────────────────────────────────────────────────
_COLOR_MODE = 'auto'
_ANSI_RE = re.compile(r'\x1b\[[0-9;]*m')


def _stdout_supports_color() -> bool:
    if os.environ.get('NO_COLOR'):
        return False
    if os.environ.get('FORCE_COLOR') or os.environ.get('CLICOLOR_FORCE'):
        return True
    return sys.stdout.isatty() and os.environ.get('TERM', '') != 'dumb'


def _use_color() -> bool:
    if _COLOR_MODE == 'always':
        return True
    if _COLOR_MODE == 'never':
        return False
    return _stdout_supports_color()


def _c(*codes: int) -> str:
    return f'\033[{";".join(map(str, codes))}m' if _use_color() else ''


RESET  = _c(0)
BOLD   = _c(1)
DIM    = _c(2)
GREEN  = _c(32)
YELLOW = _c(33)
RED    = _c(31)


def _vis(s: str) -> int:
    """Visible (printable) length of a string, ignoring ANSI escape codes."""
    return len(_ANSI_RE.sub('', s))


def fmt_state(state_text: str) -> str:
    s = state_text.upper()
    if s in READY_STATES:
        return f'{GREEN}{state_text}{RESET}'
    if s in MISSING_STATES:
        return f'{RED}{state_text}{RESET}'
    return f'{YELLOW}{state_text}{RESET}'


def fmt_ready(ready: str) -> str:
    return f'{GREEN}{ready}{RESET}' if ready == 'yes' else f'{DIM}{ready}{RESET}'


def eprint(msg: str) -> None:
    """Print a dim status/progress line to stderr."""
    print(f'{DIM}{msg}{RESET}', file=sys.stderr)

# ─────────────────────────────────────────────────────────────────────────────
_state_lock = threading.Lock()


class UsageError(Exception):
    pass


class CommandError(Exception):
    pass


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec='seconds')


def parse_iso(ts: str | None):
    if not ts:
        return None
    try:
        return datetime.fromisoformat(ts)
    except ValueError:
        return None


def should_auto_probe(state: dict) -> bool:
    # Always probe when any machine is in a transitional state (e.g. CREATING,
    # PROVISIONING) — these are not settled and the cache is immediately stale.
    for machine in state.get('machines', {}).values():
        cached = machine.get('last_seen_state', '').upper()
        if not cached:  # freshly added, never probed
            return True
        if cached not in READY_STATES and cached not in MISSING_STATES:
            return True
    last_probe = parse_iso(state.get('last_full_probe_at'))
    if last_probe is None:
        return True
    if last_probe.tzinfo is None:
        last_probe = last_probe.replace(tzinfo=timezone.utc)
    age = datetime.now(timezone.utc) - last_probe.astimezone(timezone.utc)
    return age.total_seconds() >= FULL_PROBE_TTL_SECONDS


def ensure_dir() -> None:
    TPUS_DIR.mkdir(parents=True, exist_ok=True)


def read_json(path: Path, default):
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise CommandError(f'Invalid JSON in {path}: {exc}') from exc


def write_json(path: Path, payload) -> None:
    ensure_dir()
    path.write_text(json.dumps(payload, indent=2, sort_keys=True) + '\n')


def load_state() -> dict:
    ensure_dir()
    if TPUS_STATE_JSON.exists():
        data = read_json(TPUS_STATE_JSON, {'machines': {}, 'version': 1})
        data.setdefault('machines', {})
        data.setdefault('version', 1)
        data.setdefault('last_full_probe_at', None)
        return data
    state = {'machines': {}, 'version': 1, 'last_full_probe_at': None}
    if TPUS_STATE_TSV.exists():
        for line in TPUS_STATE_TSV.read_text().splitlines():
            line = line.strip()
            if not line:
                continue
            parts = line.split()
            if len(parts) < 4:
                continue
            name, zone, accel, mode = parts[:4]
            state['machines'][name] = {
                'name': name,
                'zone': zone,
                'type': accel,
                'mode': mode,
                'note': '',
                'created_at': None,
                'setup_complete': False,
            }
        write_json(TPUS_STATE_JSON, state)
    return state


def save_state(state: dict) -> None:
    write_json(TPUS_STATE_JSON, state)


def load_config(required: bool = True) -> dict:
    if not TPUS_CONFIG.exists():
        if required:
            raise CommandError(f'No config found at {TPUS_CONFIG}')
        return {}
    config = read_json(TPUS_CONFIG, {})
    if required and not config.get('service_account'):
        raise CommandError(f'service_account not set in {TPUS_CONFIG}')
    return config


def print_json(payload) -> None:
    print(json.dumps(payload, indent=2, sort_keys=True))


def run(cmd, *, check=True, capture_output=False, text=True, input_text=None):
    result = subprocess.run(
        cmd,
        check=False,
        capture_output=capture_output,
        text=text,
        input=input_text,
    )
    if check and result.returncode != 0:
        stderr = (result.stderr or '').strip()
        stdout = (result.stdout or '').strip()
        detail = stderr or stdout or f'command failed with exit code {result.returncode}'
        raise CommandError(detail)
    return result


def gcloud(*args, check=True, capture_output=False):
    cmd = ['gcloud', *args]
    return run(cmd, check=check, capture_output=capture_output)


def editor() -> str:
    return os.environ.get('EDITOR', 'vi')


def configured_zones(config: dict) -> list[str]:
    zones = []
    default_zone = config.get('defaults', {}).get('zone')
    if default_zone:
        zones.append(default_zone)
    for slot in config.get('grant_slots', []):
        zone = slot.get('zone')
        if zone and zone not in zones:
            zones.append(zone)
    return zones


def derive_generation(accel_type: str) -> str:
    m = re.match(r'(.+)-\d+$', accel_type)
    return m.group(1) if m else accel_type


def split_type(accel_type: str) -> tuple[str, int]:
    m = re.fullmatch(r'(.+)-(\d+)', accel_type)
    if not m:
        raise CommandError(f"Invalid TPU type '{accel_type}'. Expected forms like v4-8 or v6e-32.")
    return m.group(1), int(m.group(2))


def ensure_full_type(config: dict, accel_type: str | None) -> str:
    defaults = config.get('defaults', {})
    default_type = defaults.get('type')
    if accel_type:
        m = re.match(r'.+-\d+$', accel_type)
        if m:
            return accel_type
        if default_type:
            _, size = split_type(default_type)
            return f'{accel_type}-{size}'
        size = defaults.get('size')
        if not size:
            raise CommandError('defaults.type or defaults.size not set in config.json')
        return f'{accel_type}-{size}'
    if default_type:
        return default_type
    generation = defaults.get('generation')
    size = defaults.get('size')
    if not generation or not size:
        raise CommandError('defaults.type or defaults.generation/defaults.size not set in config.json')
    return f'{generation}-{size}'


def runtime_for_type(config: dict, accel_type: str) -> str:
    versions = config.get('runtime_versions', {})
    generation = derive_generation(accel_type)
    runtime = versions.get(accel_type) or versions.get(generation)
    if not runtime:
        raise CommandError(f"No runtime_version mapping for '{generation}' or '{accel_type}' in {TPUS_CONFIG}")
    return runtime


def normalize_tpu_name(name: str) -> str:
    return name.rstrip('/').split('/')[-1]


def get_machine(state: dict, name: str):
    return state['machines'].get(normalize_tpu_name(name))


def set_machine(state: dict, machine: dict) -> None:
    machine['name'] = normalize_tpu_name(machine['name'])
    state['machines'][machine['name']] = machine


def remove_machine(state: dict, name: str) -> None:
    state['machines'].pop(normalize_tpu_name(name), None)


def parse_name_suffix(base_name: str, suffix: str | None) -> str:
    return f'{base_name}-{suffix}' if suffix else base_name


def probe_machine(name: str, zone: str):
    result = gcloud(
        'compute', 'tpus', 'tpu-vm', 'describe', name,
        f'--zone={zone}',
        '--format=json(name,state,acceleratorType)',
        check=False,
        capture_output=True,
    )
    if result.returncode != 0:
        return None
    try:
        return json.loads(result.stdout or '{}')
    except json.JSONDecodeError:
        return None


def probe_machine_across_zones(config: dict, name: str):
    zones = configured_zones(config)
    found = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(zones) or 1) as ex:
        zone_futures = {ex.submit(probe_machine, name, zone): zone for zone in zones}
        for fut in concurrent.futures.as_completed(zone_futures):
            zone = zone_futures[fut]
            info = fut.result()
            if info is not None:
                found.append((zone, info))
    return found


def _query_zone(zone: str, debug: bool) -> tuple[str, list]:
    result = gcloud(
        'compute', 'tpus', 'tpu-vm', 'list',
        f'--zone={zone}',
        '--format=json(name,state,acceleratorType)',
        check=False,
        capture_output=True,
    )
    if result.returncode != 0:
        if debug:
            eprint(f'[debug] zone {zone}: gcloud error rc={result.returncode} stderr={result.stderr.strip()!r}')
        return zone, []
    try:
        payload = json.loads(result.stdout or '[]')
    except json.JSONDecodeError:
        if debug:
            eprint(f'[debug] zone {zone}: JSON parse error stdout={result.stdout!r}')
        return zone, []
    if debug:
        eprint(f'[debug] zone {zone}: found {len(payload)} TPU(s): {[item.get("name","?") + "=" + (item.get("state") or "?") for item in payload]}')
    return zone, payload


def list_remote_machines(config: dict, debug: bool = False):
    zones = configured_zones(config)
    if debug:
        eprint(f'[debug] querying zones: {zones}')
    machines = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(zones) or 1) as ex:
        zone_futures = {ex.submit(_query_zone, zone, debug): zone for zone in zones}
        for fut in concurrent.futures.as_completed(zone_futures):
            zone, payload = fut.result()
            for item in payload:
                name = normalize_tpu_name(item.get('name', ''))
                if not name:
                    continue
                machines[name] = {
                    'name': name,
                    'zone': zone,
                    'type': item.get('acceleratorType', ''),
                    'state': item.get('state') or 'UNKNOWN',
                }
    return machines


def machine_state_text(probed) -> str:
    if not probed:
        return 'MISSING'
    return probed.get('state') or 'UNKNOWN'


def is_ready_state(state_text: str) -> bool:
    return state_text.upper() in READY_STATES


def resolve_machine(state: dict, config: dict, name: str, explicit_zone: str | None = None):
    machine = get_machine(state, name)
    if explicit_zone:
        if machine:
            machine = {**machine, 'zone': explicit_zone}
        else:
            machine = {'name': name, 'zone': explicit_zone, 'type': '', 'mode': '', 'note': ''}
        return machine
    if machine:
        return machine
    found = probe_machine_across_zones(config, name)
    if not found:
        return None
    if len(found) > 1:
        zones = ', '.join(zone for zone, _ in found)
        raise CommandError(f"TPU '{name}' found in multiple zones: {zones}. Use --zone to specify.")
    zone, info = found[0]
    return {
        'name': name,
        'zone': zone,
        'type': info.get('acceleratorType', ''),
        'mode': '',
        'note': '',
    }


def wait_for_ssh(name: str, zone: str, timeout: int = 600) -> None:
    start = time.time()
    while time.time() - start < timeout:
        result = gcloud('compute', 'tpus', 'tpu-vm', 'ssh', name, f'--zone={zone}', '--', 'true', check=False)
        if result.returncode == 0:
            print()
            return
        elapsed = int(time.time() - start)
        print(f'\r{DIM}Waiting for SSH ({elapsed}s elapsed)…{RESET}   ', end='', flush=True)
        time.sleep(5)
    print()
    raise CommandError(f"Timed out waiting for '{name}' to accept SSH")


def ssh_zone_args(name: str, state: dict, config: dict, rest: list[str]):
    zone = None
    passthrough = []
    i = 0
    while i < len(rest):
        token = rest[i]
        if token == '--':
            passthrough = rest[i + 1:]
            break
        if token == '--zone':
            if i + 1 >= len(rest):
                raise UsageError('Usage: tpus ssh <name> [--zone <zone>] [-- extra-args]')
            zone = rest[i + 1]
            i += 2
            continue
        passthrough = rest[i:]
        break
    machine = resolve_machine(state, config, name, zone)
    if not machine:
        raise CommandError(f"TPU '{name}' not found in local state or configured zones.")
    return machine['zone'], passthrough


def remote_path(name: str, path: str) -> str:
    return f'{name}:{path[1:]}' if path.startswith(':') else path


def matching_grant_slots(config: dict, accel_type: str, zone: str | None, mode: str | None):
    generation, chips = split_type(accel_type)
    defaults = config.get('defaults', {})
    desired_zone = zone
    desired_mode = mode or defaults.get('mode', 'spot')
    slots = []
    for slot in config.get('grant_slots', []):
        slot_generation = slot.get('generation') or derive_generation(slot.get('type', ''))
        slot_zone = slot.get('zone')
        slot_mode = slot.get('mode', defaults.get('mode', 'spot'))
        max_chips = slot.get('max_chips') or slot.get('chips')
        if not slot_generation or not slot_zone or max_chips is None:
            continue
        if slot_generation != generation:
            continue
        if desired_zone and slot_zone != desired_zone:
            continue
        if desired_mode and slot_mode != desired_mode:
            continue
        if chips > int(max_chips):
            continue
        slots.append({
            'generation': slot_generation,
            'zone': slot_zone,
            'mode': slot_mode,
            'max_chips': int(max_chips),
        })
    return slots


def ensure_request_allowed(config: dict, accel_type: str, zone: str | None, mode: str | None):
    slots = matching_grant_slots(config, accel_type, zone, mode)
    if slots:
        return slots
    generation, chips = split_type(accel_type)
    wanted_zone = zone or config.get('defaults', {}).get('zone') or '<unset>'
    wanted_mode = mode or config.get('defaults', {}).get('mode', 'spot')
    raise CommandError(
        f"Request '{accel_type}' in zone {wanted_zone} mode {wanted_mode} is outside configured grant_slots for generation {generation} and {chips} chips."
    )


def candidate_specs(config: dict, accel_type: str | None, zone: str | None, mode: str | None, cycle: bool, shuffle: bool = False):
    full_type = ensure_full_type(config, accel_type)
    allowed_slots = ensure_request_allowed(config, full_type, zone, mode)
    if not cycle:
        chosen_zone = zone or config.get('defaults', {}).get('zone')
        chosen_mode = mode or config.get('defaults', {}).get('mode', 'spot')
        if not chosen_zone:
            raise CommandError('No zone provided and defaults.zone is not set in config.json')
        return [(full_type, chosen_zone, chosen_mode)]

    slots = list(allowed_slots)
    if shuffle:
        random.shuffle(slots)
    return [(full_type, slot['zone'], slot['mode']) for slot in slots]


def create_machine(state: dict, config: dict, name: str, accel_type: str | None, zone: str | None, *, mode: str | None, cycle: bool, shuffle: bool = False, auto_setup: bool, auto_ssh: bool):
    if get_machine(state, name):
        raise CommandError(f"TPU '{name}' is already tracked. Remove it first with: tpus rm {name}")
    candidates = candidate_specs(config, accel_type, zone, mode, cycle, shuffle=shuffle)
    service_account = config.get('service_account')
    for try_type, try_zone, try_mode in candidates:
        runtime = runtime_for_type(config, try_type)
        cmd = [
            'compute', 'tpus', 'tpu-vm', 'create', name,
            f'--zone={try_zone}',
            f'--accelerator-type={try_type}',
            f'--version={runtime}',
            f'--service-account={service_account}',
            f'--metadata=startup-script={STARTUP_SCRIPT}',
        ]
        if try_mode == 'spot':
            cmd.append('--spot')
        eprint(f"Creating '{name}'  type={try_type}  zone={try_zone}  mode={try_mode}  runtime={runtime}")
        result = gcloud(*cmd, check=False)
        if result.returncode != 0:
            if cycle:
                eprint('Failed, trying next candidate…')
                continue
            raise CommandError(f"Failed to create '{name}'")

        machine = {
            'name': name,
            'zone': try_zone,
            'type': try_type,
            'mode': try_mode,
            'note': '',
            'created_at': now_iso(),
            'setup_complete': False,
        }
        with _state_lock:
            set_machine(state, machine)
            save_state(state)
        print('\a', end='', flush=True)
        print(f"{GREEN}Created{RESET} '{name}' in {try_zone}.")
        if auto_setup or auto_ssh:
            print(f"Waiting for '{name}' to accept SSH...")
            wait_for_ssh(name, try_zone)
        if auto_setup:
            setup_machine(state, config, name)
        if auto_ssh:
            cmd_ssh([name])
        return machine
    raise CommandError(f"All candidate zones failed for '{name}'.")


def fzf_select_slot(config: dict) -> tuple[str, str, str]:
    """Present fzf to pick a grant slot. Returns (full_type, zone, mode)."""
    defaults = config.get('defaults', {})
    default_mode = defaults.get('mode', 'spot')
    slots = []
    for slot in config.get('grant_slots', []):
        generation = slot.get('generation') or derive_generation(slot.get('type', ''))
        zone = slot.get('zone')
        mode = slot.get('mode', default_mode)
        max_chips = slot.get('max_chips') or slot.get('chips')
        if not generation or not zone or max_chips is None:
            continue
        slots.append((f'{generation}-{max_chips}', zone, mode))
    if not slots:
        raise CommandError('No grant_slots configured. Add grant_slots to config or use --default.')
    # slots entries: (generation, zone, mode, max_chips)
    entries = [(gen, z, m, str(chips)) for gen, z, m, chips in
               [(t.rsplit('-', 1)[0], z, m, t.rsplit('-', 1)[1]) for t, z, m in slots]]
    col1 = max(len(g) for g, *_ in entries)
    col2 = max(len(z) for _, z, *_ in entries)
    lines = '\n'.join(f'{g:<{col1}}  {z:<{col2}}  {m:<10}  max:{chips}' for g, z, m, chips in entries)
    header = f'{"GEN":<{col1}}  {"ZONE":<{col2}}  {"MODE":<10}  MAX'
    result = subprocess.run(
        ['fzf', f'--header={header}', '--layout=reverse', '--no-sort', '--prompt=tpu config> '],
        input=lines,
        stdout=subprocess.PIPE,
        text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        raise SystemExit(0)
    selected = result.stdout.strip()
    for g, z, m, _ in entries:
        if selected.startswith(g) and z in selected:
            return g, z, m
    # fallback: parse by position
    gen = selected[:col1].strip()
    zone = selected[col1 + 2:col1 + 2 + col2].strip()
    mode = selected[col1 + 2 + col2 + 2:col1 + 2 + col2 + 12].strip()
    return gen, zone, mode


def parse_add_args(args: list[str]):
    zone = None
    accel_type = None
    size = None
    mode = None
    cycle = False
    shuffle = False
    no_setup = False
    use_default = False
    suffix = None
    name = None
    i = 0
    while i < len(args):
        token = args[i]
        if token == '--zone':
            zone = args[i + 1]
            i += 2
        elif token == '--type':
            accel_type = args[i + 1]
            i += 2
        elif token in ('--size', '-s'):
            size = int(args[i + 1])
            i += 2
        elif token == '--spot':
            mode = 'spot'
            i += 1
        elif token == '--on-demand':
            mode = 'on-demand'
            i += 1
        elif token == '--cycle':
            cycle = True
            i += 1
        elif token == '--shuffle':
            shuffle = True
            i += 1
        elif token == '--no-setup':
            no_setup = True
            i += 1
        elif token == '--default':
            use_default = True
            i += 1
        elif token == '-n':
            suffix = args[i + 1]
            i += 2
        elif token == '--help':
            print_help('add')
            raise SystemExit(0)
        elif token.startswith('-'):
            raise UsageError('Usage: tpus add <name> [-n <suffix>] [--zone <zone>] [--type <type>] [-s <size>] [--spot|--on-demand] [--cycle] [--shuffle] [--no-setup] [--default]')
        else:
            if name is not None:
                raise UsageError('Usage: tpus add <name> [-n <suffix>] [--zone <zone>] [--type <type>] [-s <size>] [--spot|--on-demand] [--cycle] [--shuffle] [--no-setup] [--default]')
            name = token
            i += 1
    if not name:
        raise UsageError('Usage: tpus add <name> [-n <suffix>] [--zone <zone>] [--type <type>] [-s <size>] [--spot|--on-demand] [--cycle] [--shuffle] [--no-setup] [--default]')
    return normalize_tpu_name(parse_name_suffix(name, suffix)), zone, accel_type, size, mode, cycle, shuffle, no_setup, use_default


def parse_launch_range(spec: str) -> list[int]:
    if '-' in spec:
        start_s, end_s = spec.split('-', 1)
        start = int(start_s)
        end = int(end_s)
        if end < start:
            raise CommandError(f'Invalid launch range: {spec}')
        return list(range(start, end + 1))
    end = int(spec)
    if end < 1:
        raise CommandError(f'Invalid launch range: {spec}')
    return list(range(1, end + 1))


def print_table(headers: list[str], rows: list[list[str]]) -> None:
    if not rows:
        return
    widths = [len(h) for h in headers]
    for row in rows:
        for i, value in enumerate(row):
            widths[i] = max(widths[i], _vis(str(value)))
    sep = '  '
    # bold header
    hdr = sep.join(f'{BOLD}{h}{RESET}' + ' ' * (w - len(h)) for h, w in zip(headers, widths))
    print(hdr)
    # separator
    print(DIM + sep.join('─' * w for w in widths) + RESET)
    # rows – values may contain ANSI codes, use _vis for padding
    for row in rows:
        parts = [str(v) + ' ' * (w - _vis(str(v))) for v, w in zip(row, widths)]
        print(sep.join(parts))


def list_status_rows(state: dict, config: dict, probe: bool, include_util: bool = False, debug: bool = False, verbose: bool = False):
    rows = []
    if probe and verbose:
        eprint('Probing zones…')
    remote = list_remote_machines(config, debug=debug) if probe else {}
    if debug and probe:
        eprint(f'[debug] local state has {len(state["machines"])} machine(s): {sorted(state["machines"])}')
        eprint(f'[debug] remote found {len(remote)} machine(s): {sorted(remote)}')
    names = sorted(set(state['machines']) | set(remote))
    for name in names:
        local_machine = state['machines'].get(name)
        remote_machine = remote.get(name)
        machine = dict(local_machine or {})
        if remote_machine:
            machine.setdefault('name', name)
            machine['zone'] = remote_machine.get('zone', machine.get('zone', ''))
            machine['type'] = remote_machine.get('type', machine.get('type', ''))
        if probe:
            state_text = remote_machine.get('state', 'UNKNOWN') if remote_machine else 'MISSING'
        else:
            state_text = machine.get('last_seen_state', 'UNKNOWN')
        if debug:
            eprint(f'[debug] {name}: remote={remote_machine is not None} last_seen_state={machine.get("last_seen_state")!r} → resolved={state_text!r}')
        ready = 'yes' if is_ready_state(state_text) else 'no'
        row = {
            'name': name,
            'type': machine.get('type', ''),
            'mode': machine.get('mode', ''),
            'zone': machine.get('zone', ''),
            'state': state_text,
            'ready': ready,
            'note': machine.get('note', ''),
            'tracked': 'yes' if local_machine else 'no',
        }
        if probe and remote_machine:
            if not local_machine:
                local_machine = {
                    'name': name,
                    'zone': remote_machine.get('zone', ''),
                    'type': remote_machine.get('type', ''),
                    'mode': machine.get('mode', ''),
                    'note': machine.get('note', ''),
                    'created_at': None,
                    'setup_complete': False,
                }
                state['machines'][name] = local_machine
            local_machine['last_seen_state'] = state_text
            local_machine['zone'] = remote_machine.get('zone', local_machine.get('zone', ''))
            if remote_machine.get('type'):
                local_machine['type'] = remote_machine['type']
        elif probe and local_machine:
            local_machine['last_seen_state'] = state_text  # e.g. 'MISSING'
        if include_util and is_ready_state(state_text) and row['zone']:
            util_machine = {
                'name': name,
                'zone': row['zone'],
            }
            row.update(fetch_util(util_machine))
        rows.append(row)
    if probe:
        state['last_full_probe_at'] = now_iso()
        save_state(state)
    return rows


def fetch_util(machine: dict) -> dict:
    remote = (
        "export PATH=$HOME/.local/bin:$PATH\n"
        "if ! command -v uvx >/dev/null 2>&1; then\n"
        "  curl -LsSf https://astral.sh/uv/install.sh | sh >/dev/null 2>&1\n"
        "  export PATH=$HOME/.local/bin:$PATH\n"
        "fi\n"
        "uvx tpu-info"
    )
    result = gcloud(
        'compute', 'tpus', 'tpu-vm', 'ssh', machine['name'],
        f"--zone={machine['zone']}", '--', remote,
        check=False,
        capture_output=True,
    )
    if result.returncode != 0:
        return {'tpu': '?', 'hbm': '?', 'accel': '?'}

    output = (result.stdout or '') + '\n' + (result.stderr or '')

    # Parse only rows from the "TPU Runtime Utilization" table.
    # The duty cycle column always contains either a '%' or 'N/A'; other tables
    # (e.g. "TPU Chips") have unrelated numeric columns that would pollute the average.
    chip_rows = re.findall(r'\|\s*\d+\s*\|([^|]+)\|([^|]+)\|', output)
    duty_cycles: list[float] = []
    hbm_pairs: list[tuple[float, float]] = []
    for hbm_col, duty_col in chip_rows:
        duty_col = duty_col.strip()
        hbm_col = hbm_col.strip()
        if '%' not in duty_col and 'N/A' not in duty_col:
            continue  # not a utilization row
        m = re.search(r'(\d+(?:\.\d+)?)%', duty_col)
        duty_cycles.append(float(m.group(1)) if m else 0.0)
        hbm_m = re.search(r'(\d+(?:\.\d+)?)\s*GiB\s*/\s*(\d+(?:\.\d+)?)\s*GiB', hbm_col)
        if hbm_m:
            hbm_pairs.append((float(hbm_m.group(1)), float(hbm_m.group(2))))

    accel_match = re.search(r'Accelerator type:\s*([^\s]+)', output)

    util = f'{sum(duty_cycles) / len(duty_cycles):.0f}%' if duty_cycles else '?'

    return {
        'tpu': util,
        'accel': accel_match.group(1) if accel_match else machine.get('type', '?'),
    }


def setup_machine(state: dict, config: dict, name: str) -> None:
    machine = resolve_machine(state, config, name)
    if not machine:
        raise CommandError(f"TPU '{name}' not found in local state or configured zones.")
    zone = machine['zone']
    print(f"Running init script on '{name}'...")
    gcloud('compute', 'tpus', 'tpu-vm', 'ssh', name, f'--zone={zone}', '--', STARTUP_SCRIPT)
    print(f"Setting BOX_NAME='{name}'...")
    gcloud('compute', 'tpus', 'tpu-vm', 'ssh', name, f'--zone={zone}', '--', f"echo 'export BOX_NAME=\"{name}\"' >> ~/.bash_profile")
    print(f"Installing uv on '{name}'...")
    gcloud(
        'compute', 'tpus', 'tpu-vm', 'ssh', name, f'--zone={zone}', '--',
        "export PATH=$HOME/.local/bin:$PATH; command -v uvx >/dev/null 2>&1 || (curl -LsSf https://astral.sh/uv/install.sh | sh)"
    )
    machine['setup_complete'] = True
    with _state_lock:
        set_machine(state, machine)
        save_state(state)
    print('Done.')


def print_help(subcommand: str | None = None) -> None:
    if subcommand == 'add':
        print('Usage: tpus add <name> [-n <suffix>] [--zone <zone>] [--type <type>] [--spot|--on-demand] [--cycle] [--no-setup] [--default]')
        return
    if subcommand == 'launch':
        print('Usage: tpus launch <prefix> -n <N|A-B> [--zone <zone>] [--type <type>] [--spot|--on-demand] [--cycle]')
        return
    print(
        'Usage: tpus [--color=auto|always|never] <command> [args]\n\n'
        '  add <name> [-n <suffix>] [--zone <z>] [--type <t>] [--spot|--on-demand] [--cycle] [--no-setup] [--default]\n'
        '                                   Create a TPU VM (fzf config picker by default; --default skips picker).\n'
        '  launch <prefix> -n <N|A-B> [--zone <z>] [--type <t>] [--spot|--on-demand] [--cycle]\n'
        '                                   Batch-create numbered TPUs and auto-run setup.\n'
        '  rm <name> [--zone <z>] | --all [--quiet] | --preempted [--probe]\n'
        '  ls [--probe] [--ready]\n'
        '  status [--probe] [--util]\n'
        '  util [name]                        Utilization-focused view\n'
        '  note <name> <text>                 Store a local note for a TPU\n'
        '  setup <name>\n'
        '  ssh <name> [--zone <z>] [-- extra-args]\n'
        '  run <name> <command...>\n'
        '  scp <name> <src> <dst> [flags]\n'
        '  sync <name> <src> <dst> [rsync-flags...]\n'
        '  config [edit]\n'
        '  wipe\n'
    )


def parse_global_args(argv: list[str]) -> tuple[list[str], str]:
    color_mode = 'auto'
    args = list(argv)
    while args:
        token = args[0]
        if token in {'--help', '-h', 'help'}:
            break
        if token.startswith('--color='):
            value = token.split('=', 1)[1]
        elif token == '--color':
            if len(args) < 2:
                raise UsageError('Usage: tpus [--color=auto|always|never] <command> [args]')
            value = args[1]
            args = [args[0], *args[2:]]
        else:
            break
        if value not in {'auto', 'always', 'never'}:
            raise UsageError("Invalid value for --color. Expected one of: auto, always, never.")
        color_mode = value
        args = args[1:]
    return args, color_mode


def cmd_add(args: list[str]) -> None:
    state = load_state()
    name, zone, accel_type, size, mode, cycle, shuffle, no_setup, use_default = parse_add_args(args)
    config = load_config()
    if not use_default:
        sel_type, sel_zone, sel_mode = fzf_select_slot(config)
        accel_type = accel_type or sel_type
        zone = zone or sel_zone
        mode = mode or sel_mode
    if size and accel_type and not re.search(r'-\d+$', accel_type):
        accel_type = f'{accel_type}-{size}'
    create_machine(state, config, name, accel_type, zone, mode=mode, cycle=cycle, shuffle=shuffle, auto_setup=not no_setup, auto_ssh=not no_setup)


def cmd_launch(args: list[str]) -> None:
    state = load_state()
    if not args or '--help' in args:
        print_help('launch')
        return
    prefix = normalize_tpu_name(args[0])
    zone = None
    accel_type = None
    mode = None
    cycle = False
    shuffle = False
    count_spec = None
    i = 1
    while i < len(args):
        token = args[i]
        if token == '-n':
            count_spec = args[i + 1]
            i += 2
        elif token == '--zone':
            zone = args[i + 1]
            i += 2
        elif token == '--type':
            accel_type = args[i + 1]
            i += 2
        elif token == '--spot':
            mode = 'spot'
            i += 1
        elif token == '--on-demand':
            mode = 'on-demand'
            i += 1
        elif token == '--cycle':
            cycle = True
            i += 1
        elif token == '--shuffle':
            shuffle = True
            i += 1
        elif token == '--help':
            print_help('launch')
            return
        else:
            raise UsageError('Usage: tpus launch <prefix> -n <N|A-B> [--zone <zone>] [--type <type>] [--spot|--on-demand] [--cycle] [--shuffle]')
    if not count_spec:
        raise UsageError('Usage: tpus launch <prefix> -n <N|A-B> [--zone <zone>] [--type <type>] [--spot|--on-demand] [--cycle] [--shuffle]')
    config = load_config()
    indices = parse_launch_range(count_spec)

    def _launch_one(idx: int) -> tuple[str, str | None]:
        n = f'{prefix}-{idx}'
        try:
            create_machine(state, config, n, accel_type, zone, mode=mode, cycle=cycle, shuffle=shuffle, auto_setup=True, auto_ssh=False)
            return n, None
        except CommandError as exc:
            return n, str(exc)

    failures = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(indices)) as ex:
        for name, error in ex.map(_launch_one, indices):
            if error:
                failures.append((name, error))
    if failures:
        for name, error in failures:
            print(f'{name}: {error}', file=sys.stderr)
        raise SystemExit(1)


def cmd_rm(args: list[str]) -> None:
    state = load_state()
    zone = None
    all_flag = False
    quiet = False
    preempted = False
    probe = False
    name = None
    i = 0
    while i < len(args):
        token = args[i]
        if token == '--all':
            all_flag = True
            i += 1
        elif token == '--quiet':
            quiet = True
            i += 1
        elif token == '--preempted':
            preempted = True
            i += 1
        elif token == '--probe':
            probe = True
            i += 1
        elif token == '--zone':
            zone = args[i + 1]
            i += 2
        elif token == '--help':
            print('Usage: tpus rm <name> [--zone <zone>] | tpus rm --all [--quiet] | tpus rm --preempted [--probe]')
            return
        elif token.startswith('-'):
            raise UsageError('Usage: tpus rm <name> [--zone <zone>] | tpus rm --all [--quiet] | tpus rm --preempted [--probe]')
        else:
            if name is not None:
                raise UsageError('Usage: tpus rm <name> [--zone <zone>] | tpus rm --all [--quiet] | tpus rm --preempted [--probe]')
            name = token
            i += 1
    config = load_config()
    if all_flag:
        if name or preempted:
            raise UsageError('Usage: tpus rm --all [--quiet]')
        names = sorted(state['machines'])
        if not names:
            print('No TPUs tracked.')
            return
        if not quiet:
            answer = input(f'Delete all {len(names)} tracked TPU(s)? [y/N] ')
            if answer.lower() not in {'y', 'yes'}:
                print('Aborted.')
                return
        failures = []
        snapshot = {n: state['machines'][n] for n in names}

        def _rm_one(machine_name: str) -> tuple[str, bool]:
            machine = snapshot[machine_name]
            result = gcloud('compute', 'tpus', 'tpu-vm', 'delete', machine_name, f"--zone={machine['zone']}", '--quiet', check=False)
            ok = result.returncode == 0 or probe_machine(machine_name, machine['zone']) is None
            return machine_name, ok

        with concurrent.futures.ThreadPoolExecutor(max_workers=len(names)) as ex:
            for machine_name, ok in ex.map(_rm_one, names):
                if ok:
                    remove_machine(state, machine_name)
                    print(f"Removed '{machine_name}'.")
                else:
                    failures.append(machine_name)
        save_state(state)
        if failures:
            raise CommandError(f'Failed to remove: {", ".join(failures)}')
        return
    if preempted:
        machine_names = sorted(state['machines'])
        snapshot = {n: state['machines'][n] for n in machine_names}

        def _handle_preempted(machine_name: str) -> tuple[str, str | None]:
            machine = snapshot[machine_name]
            found = []
            if probe:
                found = probe_machine_across_zones(config, machine_name)
                probed = found[0][1] if len(found) == 1 else None
            else:
                probed = probe_machine(machine_name, machine['zone'])
                if probed:
                    found = [(machine['zone'], probed)]
            state_text = machine_state_text(probed)
            if not found and not probed:
                return machine_name, 'missing'
            if state_text.upper() in MISSING_STATES:
                result = gcloud('compute', 'tpus', 'tpu-vm', 'delete', machine_name, f"--zone={machine['zone']}", '--quiet', check=False)
                if result.returncode == 0 or probe_machine(machine_name, machine['zone']) is None:
                    return machine_name, state_text
            return machine_name, None

        removed = []
        with concurrent.futures.ThreadPoolExecutor(max_workers=len(machine_names) or 1) as ex:
            for machine_name, action in ex.map(_handle_preempted, machine_names):
                if action is not None:
                    remove_machine(state, machine_name)
                    removed.append(f'{machine_name} ({action})')
        save_state(state)
        if removed:
            for entry in removed:
                print(f'Removed {entry}.')
        else:
            print('No preempted TPUs found.')
        return
    if not name:
        raise UsageError('Usage: tpus rm <name> [--zone <zone>] | tpus rm --all [--quiet] | tpus rm --preempted [--probe]')
    machine = resolve_machine(state, config, name, zone)
    if not machine:
        raise CommandError(f"TPU '{name}' not found in local state or configured zones.")
    delete = gcloud('compute', 'tpus', 'tpu-vm', 'delete', name, f"--zone={machine['zone']}", check=False)
    if delete.returncode != 0:
        probed = probe_machine(name, machine['zone'])
        if probed is not None and (probed.get('state') or '').upper() in READY_STATES:
            raise CommandError(f"Failed to remove '{name}'")
    remove_machine(state, name)
    save_state(state)
    print(f"Removed '{name}'.")


def cmd_ls(args: list[str]) -> None:
    state = load_state()
    config = load_config(required=False)
    explicit_probe = '--probe' in args
    debug = '--debug' in args
    probe = explicit_probe or should_auto_probe(state)
    ready_only = '--ready' in args
    util = '--util' in args
    if '--help' in args:
        print('Usage: tpus ls [--probe] [--ready] [--util] [--debug]')
        return
    if util:
        cmd_util([])
        return
    if ready_only:
        rows = list_status_rows(state, config, probe=True, include_util=False, debug=debug, verbose=False)
        for row in rows:
            if row['ready'] == 'yes':
                print(row['name'])
        return
    rows = list_status_rows(state, config, probe=probe, include_util=False, debug=debug, verbose=explicit_probe)
    if not rows:
        print('No TPUs tracked.')
        return
    table = [[row['name'], row['type'], row['mode'], row['zone'], fmt_state(row['state'])] for row in rows]
    print_table(['NAME', 'TYPE', 'MODE', 'ZONE', 'STATE'], table)


def cmd_status(args: list[str]) -> None:
    state = load_state()
    config = load_config(required=False)
    include_util = '--util' in args
    debug = '--debug' in args
    explicit_probe = '--probe' in args or include_util
    probe = explicit_probe or should_auto_probe(state)
    if '--help' in args:
        print('Usage: tpus status [--probe] [--util] [--debug]')
        return
    rows = list_status_rows(state, config, probe=probe, include_util=include_util, debug=debug, verbose=explicit_probe)
    if not rows:
        print('No TPUs tracked.')
        return
    if include_util:
        table = [[row['name'], row['zone'], row.get('accel', row['type']), fmt_state(row['state']), row.get('tpu', '?'), row['note']] for row in rows]
        print_table(['NAME', 'ZONE', 'ACCEL', 'STATE', 'UTIL', 'NOTE'], table)
    else:
        table = [[row['name'], row['type'], row['mode'], row['zone'], fmt_state(row['state']), row['note']] for row in rows]
        print_table(['NAME', 'TYPE', 'MODE', 'ZONE', 'STATE', 'NOTE'], table)


def cmd_util(args: list[str]) -> None:
    if '--help' in args:
        print('Usage: tpus util [name] [--debug]')
        return
    state = load_state()
    config = load_config(required=False)
    debug = '--debug' in args
    filtered_args = [arg for arg in args if arg not in {'--help', '--debug'}]
    target = filtered_args[0] if filtered_args else None
    rows = list_status_rows(state, config, probe=True, include_util=True, debug=debug)
    if target:
        rows = [row for row in rows if row['name'] == target]
    if not rows:
        print('No matching TPUs tracked.')
        return
    table = [[row['name'], row['zone'], row.get('accel', row['type']), fmt_state(row['state']), row.get('tpu', '?'), row['note']] for row in rows]
    print_table(['NAME', 'ZONE', 'ACCEL', 'STATE', 'UTIL', 'NOTE'], table)


def cmd_note(args: list[str]) -> None:
    if len(args) < 2:
        raise UsageError('Usage: tpus note <name> <text>')
    name = args[0]
    note = ' '.join(args[1:]).strip()
    state = load_state()
    machine = get_machine(state, name)
    if not machine:
        machine = {'name': name, 'zone': '', 'type': '', 'mode': '', 'note': '', 'created_at': None, 'setup_complete': False}
    machine['note'] = note
    set_machine(state, machine)
    save_state(state)
    print(f"Updated note for '{name}'.")


def cmd_setup(args: list[str]) -> None:
    if len(args) != 1:
        raise UsageError('Usage: tpus setup <name>')
    state = load_state()
    config = load_config()
    setup_machine(state, config, args[0])


def cmd_ssh(args: list[str]) -> None:
    if not args:
        raise UsageError('Usage: tpus ssh <name> [--zone <zone>] [-- extra-args]')
    name = args[0]
    state = load_state()
    config = load_config(required=False)
    zone, passthrough = ssh_zone_args(name, state, config, args[1:])
    gcloud('compute', 'tpus', 'tpu-vm', 'ssh', name, f'--zone={zone}', *passthrough)


def cmd_run(args: list[str]) -> None:
    if len(args) < 2:
        raise UsageError('Usage: tpus run <name> <command...>')
    name = args[0]
    command = ' '.join(args[1:])
    state = load_state()
    config = load_config(required=False)
    machine = resolve_machine(state, config, name)
    if not machine:
        raise CommandError(f"TPU '{name}' not found in local state or configured zones.")
    gcloud('compute', 'tpus', 'tpu-vm', 'ssh', name, f"--zone={machine['zone']}", '--', command)


def cmd_scp(args: list[str]) -> None:
    if len(args) < 3:
        raise UsageError('Usage: tpus scp <name> <src> <dst> [flags]')
    name, src, dst, *extra = args
    state = load_state()
    config = load_config(required=False)
    machine = resolve_machine(state, config, name)
    if not machine:
        raise CommandError(f"TPU '{name}' not found in local state or configured zones.")
    gcloud(
        'compute', 'tpus', 'tpu-vm', 'scp',
        f'--zone={machine["zone"]}',
        remote_path(name, src),
        remote_path(name, dst),
        *extra,
    )


def cmd_sync(args: list[str]) -> None:
    if len(args) < 3:
        raise UsageError('Usage: tpus sync <name> <src> <dst> [rsync-flags...]')
    name, src, dst, *extra = args
    state = load_state()
    config = load_config(required=False)
    machine = resolve_machine(state, config, name)
    if not machine:
        raise CommandError(f"TPU '{name}' not found in local state or configured zones.")
    src = remote_path(name, src)
    dst = remote_path(name, dst)
    rsh = f"bash -c 'shift; exec gcloud compute tpus tpu-vm ssh {shlex.quote(name)} --zone={shlex.quote(machine['zone'])} -- \"$@\"' --"
    run(['rsync', '-e', rsh, src, dst, *extra])


def cmd_config(args: list[str]) -> None:
    ensure_dir()
    if args[:1] == ['edit']:
        subprocess.run([editor(), str(TPUS_CONFIG)], check=False)
        return
    if TPUS_CONFIG.exists():
        print_json(read_json(TPUS_CONFIG, {}))
    else:
        print(f'No config found at {TPUS_CONFIG}')


def cmd_wipe(args: list[str]) -> None:
    removed = False
    for path in (TPUS_STATE_JSON, TPUS_STATE_TSV):
        if path.exists():
            path.unlink()
            print(f'Removed {path}')
            removed = True
    if not removed:
        print('Nothing to wipe.')


def main(argv: list[str]) -> int:
    global _COLOR_MODE, RESET, BOLD, DIM, GREEN, YELLOW, RED
    try:
        argv, _COLOR_MODE = parse_global_args(argv)
    except UsageError as exc:
        print(str(exc), file=sys.stderr)
        return 1

    RESET  = _c(0)
    BOLD   = _c(1)
    DIM    = _c(2)
    GREEN  = _c(32)
    YELLOW = _c(33)
    RED    = _c(31)

    if not argv or argv[0] in {'help', '--help', '-h'}:
        print_help()
        return 0
    command, args = argv[0], argv[1:]
    dispatch = {
        'add': cmd_add,
        'launch': cmd_launch,
        'rm': cmd_rm,
        'ls': cmd_ls,
        'status': cmd_status,
        'util': cmd_util,
        'note': cmd_note,
        'setup': cmd_setup,
        'ssh': cmd_ssh,
        'run': cmd_run,
        'scp': cmd_scp,
        'sync': cmd_sync,
        'config': cmd_config,
        'wipe': cmd_wipe,
    }
    if command not in dispatch:
        print(f"Unknown command: '{command}'. Run 'tpus help'.", file=sys.stderr)
        return 1
    try:
        dispatch[command](args)
        return 0
    except UsageError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except CommandError as exc:
        print(str(exc), file=sys.stderr)
        return 1


if __name__ == '__main__':
    raise SystemExit(main(sys.argv[1:]))

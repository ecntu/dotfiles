# Navigation
alias d='cd ~/Documents'

# Random
alias v="vim"
alias df="df -h"
alias mkdir="mkdir -p"

alias count="ls -1 | wc -l"			        # no. of things
alias countf="ls -p | grep -v / | wc -l"	# no. of files
alias countd="ls -p | grep / | wc -l"		# no. of directories

alias dirsize="du -sh * | sort -h"

alias fpid="ps aux | fzf -m | awk '{print \$2}'" # find pid


# Trim new lines and copy to clipboard
alias c="tr -d '\n' | pbcopy"

# Copy to clipboard via OSC 52 — works over SSH/tmux unlike pbcopy.
# Requires `set -g set-clipboard on` in tmux.conf. Size-limited by the terminal.
copy() {
  local b64
  if [ -t 0 ]; then
    b64=$(printf '%s' "$*" | base64 | tr -d '\n')
  else
    b64=$(base64 | tr -d '\n')
  fi
  printf '\033]52;c;%s\a' "$b64" > /dev/tty
}

# Join all files in a dir into one output with [filename]: delimiters
joindir() {
  local dir="${1:-.}"
  for f in "$dir"/*; do
    [ -f "$f" ] || continue
    echo "[$(basename "$f")]:"
    cat "$f"
    echo
  done
}

# Recursively delete `.DS_Store` files
alias clean-ds="find . -type f -name '*.DS_Store' -ls -delete"
alias todo='rg -n "TODO|FIX"'

# Rsync but ignore .git and respect .gitignore
rsyncg() {
  rsync -avzP --exclude='.git/' --filter=':- .gitignore' "$@"
}

# System
alias tuto='sudo shutdown -h now'

alias claudio='claude --dangerously-skip-permissions'
alias cogex='codex --full-auto'

# GPU
alias gpu-util="nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits"
